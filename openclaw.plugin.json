  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "default": true,
        "type": "boolean"
      },
      "provider": {
        "type": "string",
        "enum": [
          "telnyx",
          "twilio",
          "plivo",
          "mock"
        ]
      },
      "telnyx": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "minLength": 1
          },
          "connectionId": {
            "type": "string",
            "minLength": 1
          },
          "publicKey": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "twilio": {
        "type": "object",
        "properties": {
          "accountSid": {
            "type": "string",
            "minLength": 1
          },
          "authToken": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "plivo": {
        "type": "object",
        "properties": {
          "authId": {
            "type": "string",
            "minLength": 1
          },
          "authToken": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "fromNumber": {
        "type": "string",
        "pattern": "^\\+[1-9]\\d{1,14}$"
      },
      "toNumber": {
        "type": "string",
        "pattern": "^\\+[1-9]\\d{1,14}$"
      },
      "inboundPolicy": {
        "default": "disabled",
        "type": "string",
        "enum": [
          "disabled",
          "allowlist",
          "pairing",
          "open"
        ]
      },
      "allowFrom": {
        "default": [],
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^\\+[1-9]\\d{1,14}$"
        }
      },
      "inboundGreeting": {
        "type": "string"
      },
      "inboundSecurity": {
        "default": {
          "trustStirA": true,
          "rejectUnverified": false
        },
        "type": "object",
        "properties": {
          "trustStirA": {
            "default": true,
            "type": "boolean"
          },
          "passphrase": {
            "type": "string",
            "minLength": 4
          },
          "rejectUnverified": {
            "default": false,
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "outbound": {
        "default": {
          "defaultMode": "notify",
          "notifyHangupDelaySec": 3
        },
        "type": "object",
        "properties": {
          "defaultMode": {
            "default": "notify",
            "type": "string",
            "enum": [
              "notify",
              "conversation"
            ]
          },
          "notifyHangupDelaySec": {
            "default": 3,
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "additionalProperties": false
      },
      "maxDurationSeconds": {
        "default": 1800,
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      },
      "staleCallReaperSeconds": {
        "default": 0,
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      },
      "silenceTimeoutMs": {
        "default": 800,
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      },
      "transcriptTimeoutMs": {
        "default": 180000,
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      },
      "ringTimeoutMs": {
        "default": 30000,
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      },
      "maxConcurrentCalls": {
        "default": 1,
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      },
      "serve": {
        "default": {
          "port": 3334,
          "bind": "127.0.0.1",
          "path": "/voice/webhook"
        },
        "type": "object",
        "properties": {
          "port": {
            "default": 3334,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "bind": {
            "default": "127.0.0.1",
            "type": "string"
          },
          "path": {
            "default": "/voice/webhook",
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "tailscale": {
        "default": {
          "mode": "off",
          "path": "/voice/webhook"
        },
        "type": "object",
        "properties": {
          "mode": {
            "default": "off",
            "type": "string",
            "enum": [
              "off",
              "serve",
              "funnel"
            ]
          },
          "path": {
            "default": "/voice/webhook",
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "tunnel": {
        "default": {
          "provider": "none",
          "allowNgrokFreeTierLoopbackBypass": false
        },
        "type": "object",
        "properties": {
          "provider": {
            "default": "none",
            "type": "string",
            "enum": [
              "none",
              "ngrok",
              "tailscale-serve",
              "tailscale-funnel"
            ]
          },
          "ngrokAuthToken": {
            "type": "string",
            "minLength": 1
          },
          "ngrokDomain": {
            "type": "string",
            "minLength": 1
          },
          "allowNgrokFreeTierLoopbackBypass": {
            "default": false,
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "webhookSecurity": {
        "default": {
          "allowedHosts": [],
          "trustForwardingHeaders": false,
          "trustedProxyIPs": []
        },
        "type": "object",
        "properties": {
          "allowedHosts": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "trustForwardingHeaders": {
            "default": false,
            "type": "boolean"
          },
          "trustedProxyIPs": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      },
      "streaming": {
        "default": {
          "enabled": false,
          "sttProvider": "openai-realtime",
          "sttModel": "gpt-4o-transcribe",
          "realtimeModel": "gpt-4o-realtime-preview",
          "realtimeVoice": "alloy",
          "silenceDurationMs": 800,
          "vadThreshold": 0.5,
          "streamPath": "/voice/stream",
          "realtimePolicy": {
            "enabled": true,
            "connectOnStreamStart": true,
            "closeOnStreamDisconnect": true,
            "closeAfterAssistantDone": false,
            "idleTimeoutMs": 120000,
            "maxSessionMs": 7200000,
            "maxReconnectAttempts": 5,
            "reconnectBackoffMs": 1000
          },
          "preStartTimeoutMs": 5000,
          "maxPendingConnections": 32,
          "maxPendingConnectionsPerIp": 4,
          "maxConnections": 128
        },
        "type": "object",
        "properties": {
          "enabled": {
            "default": false,
            "type": "boolean"
          },
          "sttProvider": {
            "default": "openai-realtime",
            "type": "string",
            "enum": [
              "openai-realtime",
              "openai-realtime-conversation"
            ]
          },
          "openaiApiKey": {
            "type": "string",
            "minLength": 1
          },
          "sttModel": {
            "default": "gpt-4o-transcribe",
            "type": "string",
            "minLength": 1
          },
          "realtimeModel": {
            "default": "gpt-4o-realtime-preview",
            "type": "string",
            "minLength": 1
          },
          "realtimeVoice": {
            "default": "alloy",
            "type": "string",
            "enum": [
              "alloy",
              "ash",
              "ballad",
              "coral",
              "echo",
              "sage",
              "shimmer",
              "verse"
            ]
          },
          "realtimeSystemPrompt": {
            "type": "string"
          },
          "silenceDurationMs": {
            "default": 800,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "vadThreshold": {
            "default": 0.5,
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "turnDetection": {
            "default": "server_vad",
            "type": "string",
            "enum": [
              "server_vad",
              "semantic_vad"
            ]
          },
          "vadEagerness": {
            "default": "auto",
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "auto"
            ]
          },
          "language": {
            "type": "string",
            "minLength": 2,
            "maxLength": 5
          },
          "streamPath": {
            "default": "/voice/stream",
            "type": "string",
            "minLength": 1
          },
          "realtimePolicy": {
            "default": {
              "enabled": true,
              "connectOnStreamStart": true,
              "closeOnStreamDisconnect": true,
              "closeAfterAssistantDone": false,
              "idleTimeoutMs": 120000,
              "maxSessionMs": 7200000,
              "maxReconnectAttempts": 5,
              "reconnectBackoffMs": 1000
            },
            "type": "object",
            "properties": {
              "enabled": {
                "default": true,
                "type": "boolean"
              },
              "connectOnStreamStart": {
                "default": true,
                "type": "boolean"
              },
              "closeOnStreamDisconnect": {
                "default": true,
                "type": "boolean"
              },
              "closeAfterAssistantDone": {
                "default": false,
                "type": "boolean"
              },
              "idleTimeoutMs": {
                "default": 120000,
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "maxSessionMs": {
                "default": 7200000,
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "maxReconnectAttempts": {
                "default": 5,
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "reconnectBackoffMs": {
                "default": 1000,
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "maxConsecutiveNoAudioMs": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "additionalProperties": false
          },
          "preStartTimeoutMs": {
            "default": 5000,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "maxPendingConnections": {
            "default": 32,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "maxPendingConnectionsPerIp": {
            "default": 4,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "maxConnections": {
            "default": 128,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "additionalProperties": false
      },
      "publicUrl": {
        "type": "string",
        "format": "uri"
      },
      "skipSignatureVerification": {
        "default": false,
        "type": "boolean"
      },
      "stt": {
        "default": {
          "provider": "openai",
          "model": "whisper-1"
        },
        "type": "object",
        "properties": {
          "provider": {
            "default": "openai",
            "type": "string",
